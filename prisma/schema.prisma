generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ── NextAuth models ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ──

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime?
  image                 String?
  geminiApiKeyEncrypted String? @map("geminiApiKey")
  preferredEasy         Int       @default(2)
  preferredMedium       Int       @default(3)
  preferredHard         Int       @default(2)
  preferredTopicIds     String[]  @default([])
  preferredCustomTopic  String    @default("")

  accounts    Account[]
  sessions    Session[]
  dailySets   DailySet[]
  submissions Submission[]
}

model Exercise {
  id           String   @id @default(cuid())
  japaneseText String
  difficulty   String   @default("medium")
  createdAt    DateTime @default(now())

  dailySetId String
  dailySet   DailySet @relation(fields: [dailySetId], references: [id], onDelete: Cascade)

  submissions Submission[]
}

model DailySet {
  id        String   @id @default(cuid())
  userId    String
  date      String
  topics    String[] @default([])
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  submissions Submission[]

  @@unique([userId, date])
}

model Submission {
  id              String   @id @default(cuid())
  userId          String
  exerciseId      String
  dailySetId      String
  userAnswer      String
  correctedAnswer String
  feedback        String
  score           Int
  bookmarked      Boolean  @default(false)
  createdAt       DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  dailySet DailySet @relation(fields: [dailySetId], references: [id], onDelete: Cascade)
}
